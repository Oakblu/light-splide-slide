{
  "name": "light-splide-slide",
  "version": "0.2.7",
  "description": "Headless, SSR-safe, dependency-light React slider/carousel built on native scroll-snap.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "keywords": [
    "react",
    "slider",
    "carousel",
    "headless",
    "scroll-snap",
    "ssr"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "build": "tsup && cp src/styles.css dist/styles.css",
    "size": "size-limit",
    "check": "pnpm lint && pnpm typecheck && pnpm test:cov",
    "prepublishOnly": "pnpm check && pnpm build",
    "prepare:publish": "pnpm lint:fix && pnpm format && pnpm test && pnpm build && pnpm check",
    "release:patch": "pnpm prepare:publish && npm version patch && npm publish && git push --follow-tags",
    "release:minor": "pnpm prepare:publish && npm version minor && npm publish && git push --follow-tags",
    "release:major": "pnpm prepare:publish && npm version major && npm publish && git push --follow-tags",
    "update:packages": "ncu -u"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser": "^4.1.10",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "npm-check-updates": "^22.2.9",
    "playwright": "^1.61.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "size-limit": "^12.1.0",
    "tsup": "^8.5.1",
    "@typescript/native": "npm:typescript@^7.0.2",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
